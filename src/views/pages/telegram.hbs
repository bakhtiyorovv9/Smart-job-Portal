<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Telegram bot | SmartJob</title>
  <link rel="stylesheet" href="/public/css/dashboard.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  {{> dash-topnav}}
  <div class="layout">
    {{> dash-sidebar}}
    <main class="main-content">

      <div class="page-header">
        <div>
          <h1 class="page-title">Telegram bot</h1>
          <p class="page-sub">@Smart_portal_job_bot — yangi vakansiyalar, ariza holati va kunlik hisobotlar</p>
        </div>
        <span class="online-badge"><i class="fa-solid fa-circle"></i> Online</span>
      </div>

      <div class="tg-layout">

        <!-- Chap: Bot preview -->
        <div class="tg-phone">
          <div class="tg-phone-head">
            <div class="tg-bot-av"><i class="fa-brands fa-telegram"></i></div>
            <div>
              <div class="tg-bot-name">SmartJob Bot</div>
              <div class="tg-bot-status">bot · onlayn</div>
            </div>
          </div>
          <div class="tg-phone-body">
            <div class="tg-msg bot">
              <strong>Sizning arizalaringiz</strong><br>
              📋 Jami: 4 ta<br><br>
              • Senior NestJS Backend — 🟡 Kutilmoqda<br>
              • Frontend Developer — ✅ Qabul qilindi<br>
              • DevOps Engineer — ❌ Rad etildi<br>
              • Data Analyst — 🔵 Ko'rib chiqilmoqda
              <div class="tg-time">10:27</div>
            </div>
            <div class="tg-msg user">
              /myapplications
              <div class="tg-time">10:27</div>
            </div>
            <div class="tg-msg bot">
              🎉 <strong>Yangilik</strong><br>
              "Frontend Developer (React)" arizangiz holati o'zgardi:<br><br>
              Kutilmoqda → ✅ Qabul qilindi
              <div class="tg-time">10:31</div>
            </div>
          </div>
          <div class="tg-phone-input">
            <i class="fa-solid fa-paperclip"></i>
            <span>Buyruq yozing (masalan, /jobs)</span>
            <i class="fa-solid fa-paper-plane"></i>
          </div>
        </div>

        <!-- O'ng: Ma'lumot -->
        <div class="tg-side">

          <!-- Buyruqlar -->
          <div class="tg-card">
            <h4>📋 Buyruqlar</h4>
            <div class="tg-cmd"><code>/start</code> <span>Botni boshlash</span></div>
            <div class="tg-cmd"><code>/jobs</code> <span>Yangi vakansiyalar</span></div>
            <div class="tg-cmd"><code>/myapplications</code> <span>Mening arizalarim</span></div>
            <div class="tg-cmd"><code>/help</code> <span>Yordam</span></div>
          </div>

          <!-- Bildirishnomalar -->
          <div class="tg-card">
            <h4>🔔 Bildirishnomalar</h4>
            <div class="tg-notif"><span>Yangi vakansiyalar</span> <span class="tg-on">Yoniq</span></div>
            <div class="tg-notif"><span>Ariza holati o'zgarishi</span> <span class="tg-on">Yoniq</span></div>
            <div class="tg-notif"><span>Kunlik hisobot (09:00)</span> <span class="tg-on">Yoniq</span></div>
          </div>

          <!-- Texnologiya -->
          <div class="tg-card tg-tech">
            <h4>⚙️ Texnologiya</h4>
            <p>Telegraf.js + NestJS module orqali yozilgan. Long polling rejimida ishlaydi.</p>
          </div>

          <!-- Botga ulanish -->
          <div class="tg-card">
            <h4>🔗 Akkountni ulash</h4>

            {{#if user.telegram_id}}
            <div class="tg-status on" style="margin-bottom:10px;">
              <i class="fa-solid fa-circle-check"></i> Ulangan
            </div>
            <p class="muted small">Sizning Chat ID: <code>{{user.telegram_id}}</code></p>
            <button class="btn-outline-sm" style="margin-top:10px;" onclick="disconnectTg()">
              <i class="fa-solid fa-link-slash"></i> Uzish
            </button>
            {{else}}
            <ol class="tg-steps">
              <li>Botni oching va <code>/start</code> bosing</li>
              <li>Bot bergan <strong>Chat ID</strong> (raqam) ni nusxalang</li>
              <li>Pastga joylashtirib "Ulash" tugmasini bosing</li>
            </ol>
            <a href="https://t.me/Smart_portal_job_bot" target="_blank" class="btn-primary-sm" style="margin:8px 0; display:inline-flex;">
              <i class="fa-brands fa-telegram"></i> Botni ochish
            </a>
            <div class="form-grp" style="margin-top:8px;">
              <input type="text" id="tgChatId" class="finput" placeholder="Masalan: 123456789" inputmode="numeric">
            </div>
            <button class="btn-primary-sm" onclick="connectTg()">
              <i class="fa-solid fa-link"></i> Ulash
            </button>
            {{/if}}

            <div id="tg-msg" style="display:none; margin-top:10px; font-size:14px;"></div>
          </div>

        </div>
      </div>

    </main>
  </div>

  <script>
    const TG_USER_ID = parseInt('{{#if user.id}}{{user.id}}{{else}}0{{/if}}', 10) || 0;

    async function connectTg() {
      const val = document.getElementById('tgChatId').value.trim();
      const msg = document.getElementById('tg-msg');
      msg.style.display = 'block';

      if (!/^\d{5,15}$/.test(val)) {
        msg.style.color = '#dc2626';
        msg.textContent = "Chat ID faqat raqamlardan iborat bo'lishi kerak. Botdan /start orqali oling.";
        return;
      }
      try {
        const res = await fetch('/api/users/' + TG_USER_ID, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ telegram_id: val }),
        });
        const json = await res.json();
        if (res.ok && (json.success || json.data)) {
          msg.style.color = '#15803d';
          msg.textContent = '✅ Ulandi! Botda /myapplications yoki /jobs yozib tekshiring.';
          setTimeout(() => location.reload(), 1300);
        } else {
          msg.style.color = '#dc2626';
          msg.textContent = Array.isArray(json.message) ? json.message.join(', ') : (json.message || 'Xatolik');
        }
      } catch (e) {
        msg.style.color = '#dc2626';
        msg.textContent = 'Tarmoq xatosi';
      }
    }

    async function disconnectTg() {
      if (!confirm('Telegram akkountni uzmoqchimisiz?')) return;
      try {
        await fetch('/api/users/' + TG_USER_ID, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ telegram_id: '' }),
        });
        location.reload();
      } catch (e) {}
    }
  </script>

  <style>
    .tg-steps { margin:6px 0 4px; padding-left:18px; color:#374151; font-size:14px; line-height:1.8; }
    .tg-steps code { background:#eef2ff; padding:1px 6px; border-radius:5px; }
    .tg-status.on { color:#15803d; font-weight:600; }
    .tg-status.off { color:#dc2626; font-weight:600; }
  </style>
</body>
</html>