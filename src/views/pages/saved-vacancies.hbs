<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Saqlangan vakansiyalar | SmartJob</title>
  <link rel="stylesheet" href="/public/css/dashboard.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  {{> dash-topnav}}
  <div class="layout">
    {{> dash-sidebar}}
    <main class="main-content">

      <div class="page-header">
        <div>
          <h1 class="page-title">Saqlangan vakansiyalar</h1>
          <p class="page-sub" id="saved-count">{{savedVacancies.length}} ta vakansiya saqlangan</p>
        </div>
      </div>

      {{#if savedVacancies.length}}
      <div class="saved-list" id="saved-list">
        {{#each savedVacancies}}
        <div class="saved-card" id="sv-{{this.id}}">
          <div class="co-av-md">{{initials this.company.name}}</div>
          <div class="sv-info">
            <div class="sv-title-row">
              <h3>{{this.title}}</h3>
            </div>
            <p class="sv-company">{{this.company.name}} · {{this.location}}</p>
            <div class="sv-meta">
              <span><i class="fa-solid fa-location-dot"></i> {{this.location}}</span>
              <span><i class="fa-regular fa-clock"></i> To'liq stavka</span>
              {{#if this.category}}
              <span><i class="fa-solid fa-tag"></i> {{this.category.name}}</span>
              {{/if}}
            </div>
          </div>
          <div class="sv-right">
            <div class="sv-salary">{{formatSalary this.salary}}</div>
            <div class="muted small">{{timeAgo this.created_at}}</div>
            <button class="bookmark-filled" onclick="removeSaved({{this.id}}, this)">
              <i class="fa-solid fa-bookmark"></i>
            </button>
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="empty-box">
        <i class="fa-regular fa-bookmark fa-3x muted"></i>
        <p>Hozircha saqlangan vakansiyalar yo'q.</p>
        <a href="/vacancies" class="btn-primary-sm">Vakansiyalarni ko'rish</a>
      </div>
      {{/if}}

    </main>
  </div>

  <script>
    async function removeSaved(id, btn) {
      try {
        const res = await fetch(`/api/saved-vacancies/${id}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        const json = await res.json();
        if (json.success) {
          document.getElementById(`sv-${id}`).remove();
          const cnt = document.querySelectorAll('.saved-card').length;
          document.getElementById('saved-count').textContent = `${cnt} ta vakansiya saqlangan`;
        }
      } catch (e) { console.error(e); }
    }
  </script>
</body>
</html>